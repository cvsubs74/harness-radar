{
  "$comment": "Declarative label set for engineering-workflow harness. Synced by scripts/gh-bootstrap.sh. Edit area:* entries during /kickoff to match the product's domains.",
  "labels": [
    {"name": "type:epic",            "color": "5319e7", "description": "Cross-cutting capability spanning multiple stories"},
    {"name": "type:story",           "color": "1d76db", "description": "A buildable, testable feature"},
    {"name": "type:bug",             "color": "d73a4a", "description": "A defect to fix"},
    {"name": "type:spike",           "color": "fbca04", "description": "Time-boxed investigation or research"},

    {"name": "priority:P0",          "color": "b60205", "description": "Must build now"},
    {"name": "priority:P1",          "color": "d93f0b", "description": "Should build soon"},
    {"name": "priority:P2",          "color": "fbca04", "description": "Nice to have"},

    {"name": "area:cli",             "color": "0075ca", "description": "CLI entrypoint, argument parsing, exit codes"},
    {"name": "area:collector",       "color": "0075ca", "description": "gh / GraphQL data collection from target repos"},
    {"name": "area:metrics",         "color": "0075ca", "description": "Lead time, throughput, pipeline-stage timing, AC re-edit detection"},
    {"name": "area:report",          "color": "0075ca", "description": "Markdown / HTML report rendering"},
    {"name": "area:cache",           "color": "0075ca", "description": "Local cache of gh / GraphQL responses"},
    {"name": "area:infra",           "color": "0075ca", "description": "Build / packaging / CI / install"},

    {"name": "meta:blocked",         "color": "ededed", "description": "Blocked on something external"},
    {"name": "meta:needs-discussion","color": "ededed", "description": "Acceptance criteria need clarification"},
    {"name": "meta:bootstrap",       "color": "ededed", "description": "Created during /kickoff for audit trail"}
  ]
}
