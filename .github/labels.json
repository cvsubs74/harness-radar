    {"name": "area:server",          "color": "0075ca", "description": "Backend / API"},
    {"name": "area:client",          "color": "0075ca", "description": "Frontend / UI"},
    {"name": "area:db",              "color": "0075ca", "description": "Database / migrations"},
    {"name": "area:infra",           "color": "0075ca", "description": "Build / deploy / CI"},

    {"name": "meta:blocked",         "color": "ededed", "description": "Blocked on something external"},
    {"name": "meta:needs-discussion","color": "ededed", "description": "Acceptance criteria need clarification"},
